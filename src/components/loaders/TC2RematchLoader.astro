---

---

<tc2-rematch-loader></tc2-rematch-loader>

<script>
  class TC2RematchLoader extends HTMLElement {
    private pageLoadHandler = () => this.init();
    private observer: IntersectionObserver | null = null;

    connectedCallback() {
      document.addEventListener("astro:page-load", this.pageLoadHandler);

      if (document.querySelector(".hover-swap-trigger")) {
        this.init();
      }
    }

    disconnectedCallback() {
      document.removeEventListener("astro:page-load", this.pageLoadHandler);
      if (this.observer) {
        this.observer.disconnect();
      }
    }

    init() {
      const hoverCards = document.querySelectorAll(".hover-swap-trigger");
      if (hoverCards.length === 0) return;

      if (this.dataset.initialized) return;
      this.dataset.initialized = "true";

      let swapImageTimeout: NodeJS.Timeout | null = null;
      hoverCards.forEach((card: any) => {
        card.addEventListener("mouseenter", () => {
          if (swapImageTimeout) {
            clearTimeout(swapImageTimeout);
            swapImageTimeout = null;
          }
          const targetId = card.getAttribute("data-target");
          const targetEl: any = document.getElementById(targetId);
          const newSrc = card.getAttribute("data-img");

          if (newSrc && targetEl) {
            if (!targetEl.hasAttribute("data-default")) {
              targetEl.setAttribute(
                "data-default",
                targetEl.firstElementChild?.src ?? targetEl.innerText,
              );
            }
            if (targetEl.firstElementChild?.src) {
              targetEl.firstElementChild.src = newSrc;
            } else {
              targetEl.innerText = newSrc;
            }

            // Extract accent color and apply to target and self
            const accent = card.getAttribute("data-accent") || "#ff8800";
            targetEl.style.borderColor = accent;
            targetEl.style.color = "#fff";
            card.style.borderLeftColor = accent;

            // Trigger CSS reflow animation
            targetEl.classList.remove("pulse-anim");
            void targetEl.offsetWidth;
            targetEl.classList.add("pulse-anim");
          }
        });

        function swapImage() {
          const targetId = card.getAttribute("data-target");
          const targetEl: any = document.getElementById(targetId);
          card.style.borderLeftColor = ""; // remove hover accent
          if (targetEl && targetEl.hasAttribute("data-default")) {
            if (targetEl.firstElementChild?.src) {
              targetEl.firstElementChild.src =
                targetEl.getAttribute("data-default");
            } else {
              targetEl.innerText = targetEl.getAttribute("data-default");
            }
            targetEl.style.borderColor = "";
            targetEl.style.color = "";
          }
        }

        card.addEventListener("mouseleave", () => {
          if (swapImageTimeout) {
            clearTimeout(swapImageTimeout);
            swapImageTimeout = null;
          }
          swapImageTimeout = setTimeout(swapImage, 500);
          const targetId = card.getAttribute("data-target");
          const targetEl: any = document.getElementById(targetId);
          card.style.borderLeftColor = ""; // remove hover accent
          if (targetEl && targetEl.hasAttribute("data-default")) {
            targetEl.style.borderColor = "";
            targetEl.style.color = "";
          }
        });
      });

      // 2. Hydro Carousel Logic
      const hydroBtns = document.querySelectorAll(".hydro-nav-btn");
      const hydroImgs = document.querySelectorAll(".hydro-asset");

      hydroBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const targetSlide = btn.getAttribute("data-slide");

          // Update buttons
          hydroBtns.forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");

          // Swap images
          hydroImgs.forEach((img) => {
            if (img.id === `hydro-img-${targetSlide}`) {
              img.classList.remove("hidden");
              img.classList.add("active", "pulse-anim");
            } else {
              img.classList.remove("active", "pulse-anim");
              img.classList.add("hidden");
            }
          });
        });
      });

      // 3. Reveal Animation Logic
      this.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              this.observer?.unobserve(entry.target); // Reveal exactly once
            }
          });
        },
        { rootMargin: "0px", threshold: 0.1 },
      );

      document
        .querySelectorAll(".reveal-up")
        .forEach((el) => this.observer?.observe(el));
    }
  }

  if (!customElements.get("tc2-rematch-loader")) {
    customElements.define("tc2-rematch-loader", TC2RematchLoader);
  }
</script>
