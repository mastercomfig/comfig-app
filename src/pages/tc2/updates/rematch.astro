---
import Body from "@components/Body.astro";
import Footer from "@components/Footer.astro";
import BaseHead from "@components/head/BaseHead.astro";
import ImportHead from "@components/head/ImportHead.astro";
import MainHead from "@components/head/MainHead.astro";
import PreloadHead from "@components/head/PreloadHead.astro";

import tfLogoImg from "@img/tc2/team-comtress-2.png";
import mainmenuImg from "@img/tc2/rematch/tc2mainmenu.png";
import playmenuImg from "@img/tc2/rematch/playmenu.png";
import classIntelImg from "@img/tc2/rematch/classintel.png";
import settingsImg from "@img/tc2/rematch/tc2settings.png";
import seriesImg from "@img/tc2/rematch/tc2series.png";
import stopwatchImg from "@img/tc2/rematch/tc2stopwatch.png";
import shuffleImg from "@img/tc2/rematch/tc2shuffle.png";
import compImg from "@img/tc2/rematch/tc2comp.png";
import configsImg from "@img/tc2/rematch/tc2configs.png";
import classlimitImg from "@img/tc2/rematch/tc2classlimit.png";
import rolloutImg from "@img/tc2/rematch/tc2rollout.png";
import readyupImg from "@img/tc2/rematch/tc2readyup.png";
import movementsubsteppingImg from "@img/tc2/rematch/tc2movementsubstepping.jpg";
import knockbackImg from "@img/tc2/rematch/tc2knockback.png";
import critsvoteImg from "@img/tc2/rematch/tc2critsvote.png";
import tc2FightImg from "@img/tc2/rematch/tc2fight.png";
import tc2RedeployImg from "@img/tc2/rematch/tc2redeploy.png";
import tc2NodesImg from "@img/tc2/rematch/tc2nodes.png";
import spec1Img from "@img/tc2/rematch/tc2spec1.png";
import spec2Img from "@img/tc2/rematch/tc2spec2.png";
import gsiImg from "@img/tc2/rematch/tc2gsi.png";
import linesImg from "@img/tc2/rematch/tc2lines.png";
import Layout from "@layouts/Layout.astro";
import { Content as NotesBlock } from "@posts/data/rematch.mdx";

import "@fontsource-variable/inter/wght.css";
import "@fontsource-variable/oswald/wght.css";
import "@fontsource-variable/teko/wght.css";
---

<style>
  body.rematch-page {
    background-color: #0c0b0f;
    color: #e2e4e9;
    font-family: "Inter Variable", sans-serif;
    overflow-x: hidden;
  }

  /* Typography */
  .font-display {
    font-family: "Teko Variable", sans-serif;
    font-weight: 700;
    text-transform: uppercase;
  }
  .font-header {
    font-family: "Oswald Variable", sans-serif;
    text-transform: uppercase;
  }
  .font-body {
    font-family: "Inter Variable", sans-serif;
  }

  /* Palette */
  .color-red {
    color: #fe2e2e !important;
  }
  .color-orange {
    color: #ff8800 !important;
  }
  .color-blue {
    color: #2ea2ff !important;
  }
  .color-muted {
    color: #a1a6b0 !important;
  }
  .color-white {
    color: #ffffff !important;
  }

  /* Hero */
  .rematch-hero {
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background:
      radial-gradient(circle at center, #1f1412a3 0%, #0c0b0fd9 70%),
      url("/img/tc2/rematch/rematchbg.jpg");
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    padding: 2rem;
    border-bottom: 4px solid #ff8800;
  }
  .rematch-hero-title {
    font-size: clamp(5rem, 15vw, 12rem);
    line-height: 0.85;
    color: #fff;
    text-shadow: 0 10px 30px rgb(95, 95, 95);
    margin-bottom: 1.5rem;
    letter-spacing: -2px;
  }
  .rematch-hero-subtitle {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 500;
    color: #a1a6b0;
    letter-spacing: 2px;
  }

  /* Structural Flow */
  .asym-section {
    padding: 8rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 5;
  }

  .feature-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4rem;
  }
  .feature-row.reverse {
    flex-direction: row-reverse;
  }
  .feature-text {
    flex: 1 1 500px;
  }
  .feature-visual {
    flex: 1 1 500px;
  }

  .big-header {
    font-size: clamp(3.5rem, 6vw, 6.5rem);
    line-height: 1;
    margin-bottom: 1rem;
    color: #fff; /* Default, overridden by .color-* */
  }
  .sub-header {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    letter-spacing: 1px;
    color: #fff; /* Default, overridden by .color-* */
  }
  .body-text {
    font-size: 1.25rem;
    color: #b0b4bc;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  /* Skewed Flow Breaks */
  .skew-bg-red {
    background: linear-gradient(135deg, #18181c 0%, #0d0d11 100%);
    border-top: 5px solid #fe2e2e;
    border-bottom: 5px solid #fe2e2e;
    transform: skewY(-3deg);
    margin: 8rem 0;
    z-index: 10;
  }
  .skew-bg-red > .unskew {
    transform: skewY(3deg);
    padding: 8rem 2rem;
  }

  .skew-bg-metal {
    background: #111115;
    border-top: 5px solid #555;
    border-bottom: 5px solid #555;
    transform: skewY(2deg);
    margin: 8rem 0;
    z-index: 10;
  }
  .skew-bg-metal > .unskew {
    transform: skewY(-2deg);
    padding: 8rem 2rem;
  }

  /* Callouts */
  .massive-callout {
    background: url(https://teamcomtress.com/img/tc2/team-comtress-2.png) center
      center no-repeat;
    background-blend-mode: multiply;
    background-color: #0c0b0f;
    background-size: cover;
    padding: 12rem 2rem;
    text-align: center;
    border-top: 5px solid #fe2e2e;
    border-bottom: 5px solid #fe2e2e;
    position: relative;
    margin: 8rem 0;
  }
  .massive-callout::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 0;
  }
  .massive-callout > div {
    position: relative;
    z-index: 1;
  }

  /* CSS Image Placeholders */
  .asset-placeholder {
    background-color: #1a1a20;
    border: 3px dashed #444;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
    font-weight: bold;
    font-size: 1.3rem;
    letter-spacing: 2px;
    box-shadow:
      inset 0 0 50px rgba(0, 0, 0, 0.8),
      0 20px 50px rgba(0, 0, 0, 0.5);
    width: 100%;
    transition:
      transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      border-color 0.3s ease,
      color 0.3s ease;
    text-align: center;
    padding: 2rem;
  }
  .asset-placeholder.interactive-target:hover {
    border-color: #fff !important;
    color: #fff !important;
    transform: perspective(1000px) rotateY(2deg) scale(1.02);
  }

  .ratio-16x9 {
    aspect-ratio: 16/9;
  }
  .ratio-21x9 {
    aspect-ratio: 21/9;
  }
  .ratio-1x1 {
    aspect-ratio: 1/1;
  }
  .ratio-4x3 {
    aspect-ratio: 4/3;
  }

  /* Component Grid Layouts */
  .grid-layout-small {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .grid-layout-vertical {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .grid-card-small {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1.5rem;
    border-left: 4px solid #444;
    transition:
      border-left-color 0.2s,
      background 0.2s,
      transform 0.2s;
    cursor: default;
  }
  .grid-card-small:hover {
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-3px);
  }
  .grid-card-small.hover-swap-trigger {
    cursor: pointer;
  }
  .grid-card-small h4 {
    font-family: "Oswald Variable", sans-serif;
    font-size: 1.4rem;
    color: #e2e4e9;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .grid-card-small p {
    font-family: "Inter Variable", sans-serif;
    font-size: 1.05rem;
    color: #a1a6b0;
    line-height: 1.6;
    margin: 0;
  }

  @keyframes pulseOpacity {
    0% {
      opacity: 0.5;
      transform: scale(0.98);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
  .pulse-anim {
    animation: pulseOpacity 0.3s ease-out forwards;
  }

  /* JS Carousel Styles */
  .hydro-carousel-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .hydro-carousel-visual {
    position: relative;
    min-height: 300px;
  }
  .hydro-asset {
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .hydro-asset.hidden {
    opacity: 0;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
    transform: scale(0.99);
  }
  .hydro-carousel-nav {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .hydro-nav-btn {
    flex: 1;
    min-width: 250px;
    background: rgba(0, 0, 0, 0.3);
    border: 2px solid #333;
    padding: 1.5rem;
    text-align: left;
    cursor: pointer;
    transition: 0.3s ease;
    border-radius: 8px;
  }
  .hydro-nav-btn.active,
  .hydro-nav-btn:hover {
    border-color: #ff8800;
    border-bottom-color: #ff8800;
    background: rgba(255, 136, 0, 0.05);
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
  }
  .hydro-nav-btn h4 {
    color: #fff;
    font-family: "Oswald Variable", sans-serif;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 1.2rem;
  }
  .hydro-nav-btn p {
    color: #888;
    font-family: "Inter Variable", sans-serif;
    margin: 0;
    font-size: 1rem;
  }

  /* Uniform Class Layout */
  .uniform-class-list {
    display: flex;
    flex-direction: column;
    max-width: 1000px;
    margin: 0 auto;
  }
  .class-revision-row {
    display: flex;
    align-items: flex-start;
    padding: 3.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: transparent;
  }
  .class-revision-row:last-child {
    border-bottom: none;
  }
  .class-icon-block {
    flex: 0 0 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-right: 4rem;
  }
  .class-details-block {
    flex: 1;
  }
  .class-icon-block h3 {
    font-family: "Oswald Variable", sans-serif;
    font-size: 1.8rem;
    color: #fff;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.9;
  }

  /* Class Detail Bullets */
  .merc-bullets ul {
    list-style-type: none;
    padding-left: 0;
    margin: 0;
  }
  .merc-bullets li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
    line-height: 1.6;
    color: #a1a6b0;
    font-size: 1.15rem;
  }
  .merc-bullets li:last-child {
    margin-bottom: 0;
  }
  .merc-bullets li::before {
    content: "■";
    position: absolute;
    left: 0;
    top: 5px;
    color: #666;
    font-size: 0.9rem;
  }
  .merc-bullets li strong {
    color: #fff;
    font-family: "Oswald Variable", sans-serif;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-right: 0.5rem;
  }

  @media (max-width: 768px) {
    .class-revision-row {
      flex-direction: column;
      text-align: left;
      align-items: center;
      padding: 2rem 0;
    }
    .class-icon-block {
      flex: none;
      padding-right: 0;
      margin-bottom: 1.5rem;
    }
  }

  /* Reveal Animations */
  .reveal-up {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.8s cubic-bezier(0.165, 0.84, 0.44, 1),
      transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .reveal-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Patch Notes Container */
  .patch-notes-wrapper {
    background: #0c0b0f;
    padding: 6rem 2rem;
    border-top: 1px solid #333;
  }
  .patch-notes-inner {
    max-width: 1000px;
    margin: 0 auto;
    background: #111115;
    padding: 4rem;
    border-radius: 8px;
    border: 1px solid #222;
  }
  .mdx-content h2 {
    color: #fff;
    font-size: 2.2rem;
    text-transform: uppercase;
    border-bottom: 1px solid #333;
    padding-bottom: 0.5rem;
    margin-top: 3rem;
    font-family: "Oswald Variable", sans-serif;
  }
  .mdx-content h3 {
    color: #fff;
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-family: "Inter Variable", sans-serif;
  }
  .mdx-content ul {
    list-style-type: none;
    padding-left: 1rem;
  }
  .mdx-content ul li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.8rem;
    line-height: 1.6;
    color: #a1a6b0;
  }
  .mdx-content ul li::before {
    content: "■";
    position: absolute;
    left: 0;
    top: 0;
    color: #666;
    font-size: 0.8rem;
  }
</style>

<Layout>
  <head>
    <BaseHead />
    <PreloadHead />
    <ImportHead />
    <MainHead
      title="The Rematch Update | Team Comtress 2"
      site="Team Comtress"
      noSite={true}
      description="It's time for a rematch."
      image="https://teamcomtress.com/img/tc2/rematch/tc2rematch.png"
      favicon="/img/tc2/favicon.ico"
      largeImage={true}
    />
  </head>

  <Body class="rematch-page">
    <header
      class="rematch-hero text-center"
      style=`border-bottom: 1px solid #333`
    >
      <a href="/">
        <img
          src={tfLogoImg.src}
          alt="TC2 Logo"
          style="height: 110px; opacity: 0.9;"
          class="mb-4"
        />
      </a>
      <h1 class="rematch-hero-title font-display">
        It's time for a <strong>rematch</strong>.
      </h1>
      <h2 class="rematch-hero-subtitle font-header color-orange mt-3">
        The definitive matchmaking experience. Built from the ground up.
      </h2>
    </header>

    <section
      class="asym-section reveal-up"
      style="padding-top: 10rem;max-width: none;"
    >
      <div class="feature-row">
        <div class="feature-text" style="max-width: 700px">
          <h2 class="font-display color-orange big-header">A Warm Welcome</h2>
          <p class="body-text">
            The improvements start before you even join a match. We've
            overhauled the main menu using entirely new technology, giving it a
            sleek design and more modern tools to help you enjoy the game.
          </p>

          <div class="grid-layout-small">
            <div
              class="grid-card-small hover-swap-trigger"
              data-target="img-target-menus"
              data-img={playmenuImg.src}
              data-accent="#ff8800"
            >
              <h4 class="color-white">Improved Play Menu</h4>
              <p>
                We've completely streamlined the matchmaking interface,
                utilizing dynamic hover effects and kinetic data streams to make
                queuing up faster and more engaging than ever.
              </p>
            </div>
            <div
              class="grid-card-small hover-swap-trigger"
              data-target="img-target-menus"
              data-img={classIntelImg.src}
              data-accent="#ff8800"
            >
              <h4 class="color-white">Class Intel Folders</h4>
              <p>
                Explore the intricate lore and mechanical depth of every
                mercenary through highly detailed, interactive classified intel
                folders accessible directly from the main menu.
              </p>
            </div>
            <div
              class="grid-card-small hover-swap-trigger"
              data-target="img-target-menus"
              data-img={settingsImg.src}
              data-accent="#ff8800"
            >
              <h4 class="color-white">Overhauled Settings</h4>
              <p>
                Crucial gameplay options are no longer hidden behind obscure
                advanced menus or console cvars, giving you immediate access to
                search through and tailor your experience.
              </p>
            </div>
          </div>
        </div>
        <br />
        <div class="feature-visual">
          <div
            class="asset-placeholder interactive-target"
            id="img-target-menus"
            style="width: 100%;max-height: 800px"
          >
            <img
              class="img-fluid"
              style="max-height: 740px"
              src={mainmenuImg.src}
              alt="Main Menu"
            />
          </div>
        </div>
      </div>
    </section>

    <div class="skew-bg-red">
      <div class="unskew asym-section">
        <div class="text-center mb-5 pb-5 reveal-up">
          <h2
            class="font-display color-red"
            style="font-size: 6rem; line-height: 1;"
          >
            CASUAL MATCHMAKING 2.0
          </h2>
          <p class="body-text mx-auto" style="max-width: 800px; color: #ccc;">
            TF2 fans, we hear you. Matchmaking feels broken, and the fixes added
            over the years don't add up to a satisfying experience. So we've
            gone through all of its systems and rebuilt them from the ground up
            to ensure that Casual is fun, fair, and actually respects your time.
          </p>
        </div>

        <div class="feature-row mb-5 pb-5 reveal-up">
          <div class="feature-text text-start">
            <h3 class="font-header color-red sub-header">The Series System</h3>
            <p class="body-text">
              The biggest complaint we've heard from players about Casual is
              that the match structure is too short. Just when you start
              enjoying a game with your team, the match ends and you're back in
              the chaos of the queue. <strong>No more.</strong> We've now transformed
              that match experience into combined "mini-matches" called Series. Series
              are played continuously on the same map for a minimum of 35 minutes.
              The team with the most series points at the end of the match wins.
            </p>
          </div>
          <div class="feature-visual">
            <div class="asset-placeholder ratio-21x9">
              <img class="img-fluid" src={seriesImg.src} alt="Series UI" />
            </div>
          </div>
        </div>

        <div class="feature-row reverse mb-5 pb-5 reveal-up">
          <div class="feature-text text-start">
            <h3 class="font-header color-red sub-header">Hybrid Stopwatch</h3>
            <p class="body-text">
              <strong>Stopwatch is back, reworked for Casual!</strong>
              Rather than ending the round abruptly like before, each team gets a
              chance to attack and defend to the very end. While defending, if a
              team succesfully stops the attackers, they receive 1 Series Point.
              Another Series Point is awarded to the team with the best offense,
              as measured through Stopwatch.
            </p>
          </div>
          <div class="feature-visual">
            <div class="asset-placeholder ratio-16x9">
              <img
                class="img-fluid"
                src={stopwatchImg.src}
                alt="Stopwatch UI"
              />
            </div>
          </div>
        </div>

        <div class="feature-row reveal-up">
          <div class="feature-text text-start">
            <h3 class="font-header color-red sub-header">Dynamic Balance</h3>
            <p class="body-text">
              We've completely overhauled the way we balance teams in Casual.
              Auto-balance kicks in much faster to address missing teammates,
              while also considering more factors in selecting who to balance
              and when, reducing frustrating auto-balance moments. The new Team
              Shuffle system acts in between each Series, selectively adjusting
              a few players if a skill imbalance is detected, with as little
              disruption as possible, making sure teams are always on a level
              playing field, no matter who joins the match.
            </p>
          </div>
          <div class="feature-visual">
            <div class="asset-placeholder ratio-21x9">
              <img class="img-fluid" src={shuffleImg.src} alt="Shuffle UI" />
            </div>
          </div>
        </div>

        <div class="text-center mt-5 reveal-up">
          <h3 class="font-header color-red sub-header">Social Features</h3>
          <p class="body-text">
            We've made Casual more casual and fun with new social features in
            the classic spirit of Team Fortress.

            <ul class="text-start" style="display: inline-block">
              <li>
                <strong>All-Talk Between Rounds:</strong> Voice chat across teams
                is now enabled between rounds, allowing for more social interaction
                after you beat the other team.
              </li>
              <li>
                <strong>Streamlined Pre-Game:</strong> The pre-game countdown has
                been streamlined to be more reactive to wait times and joining players,
                and countdowns between rounds have been reduced across the board.
              </li>
              <li>
                <strong>Team Switching:</strong> Players can now switch teams during
                gameplay. Play with or against your friends!
              </li>
              <li>
                <strong>Spectator Slots:</strong> We've added 8 extra slots for spectators
                to view the 12v12 action, and players can switch to spectator as
                they please.
              </li>
              <li>
                <strong>Casual Bots:</strong> We've revamped bots to fit into the
                casual atmosphere, with improved behavior and item usage, to keep
                games going as players join and leave.
              </li>
            </ul>
          </p>
        </div>
      </div>
    </div>

    <section class="asym-section reveal-up">
      <div class="feature-row">
        <div class="feature-text text-start">
          <h2 class="font-display color-blue big-header">
            COMPETITIVE OVERHAUL
          </h2>
          <p class="body-text">
            In attempting to make competitive for everyone, it ended up being
            right for no one. Instead of trying to rough it out, we've decided
            it's best to make it easier for the already established competitive
            community to get into. We've also added some cool new goodies along
            the way.
          </p>

          <div class="grid-layout-small">
            <div
              class="grid-card-small hover-swap-trigger"
              data-target="img-target-comp"
              data-img={classlimitImg.src}
              data-accent="#2ea2ff"
            >
              <h4 class="color-white">Class Limits & Weapon Bans</h4>
              <p>
                Game balance purity isn't worth it if no one plays. 6s class
                limits are now enforced (2 of every class, except 1 for Medic
                and Demo). We've also added global weapon bans to make things
                feel more at home for competitive players.
              </p>
            </div>
            <div
              class="grid-card-small hover-swap-trigger"
              data-target="img-target-comp"
