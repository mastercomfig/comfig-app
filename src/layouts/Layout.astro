<html lang="en-US" data-bs-theme="dark" transition:animate="none">
  <slot />

  <script>
    import { getNonce } from "@utils/nonce";

    const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
    document.addEventListener("astro:page-load", () => {
      if (!mediaQuery.matches) {
        setTimeout(() => {
          document.documentElement.style.scrollBehavior = "smooth";
        }, 33);
      }

      document.querySelectorAll("video").forEach((video) => {
        try {
          video.load();
          if (video.hasAttribute("autoplay")) {
            video.play().catch((err) => {
              console.warn("Failed to autoplay video on page load:", err);
            });
          }
        } catch (e) {
          console.warn("Failed to reset video element on page load:", e);
        }
      });
    });

    document.addEventListener("astro:before-swap", (event) => {
      document.querySelectorAll("video").forEach((video) => {
        try {
          video.pause();
        } catch (e) {
          console.warn("Failed to pause video element during navigation:", e);
        }
      });

      const nonce = getNonce();
      if (nonce) {
        const newScripts = event.newDocument.querySelectorAll("script");
        newScripts.forEach((script) => {
          script.setAttribute("nonce", nonce);
        });
      }
    });
  </script>


</html>
